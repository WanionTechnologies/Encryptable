# Auto Configure
org.springframework.boot.autoconfigure.EnableAutoConfiguration=\
  tech.wanion.encryptable.config.auto.EncryptableAutoConfiguration

# Early Run Listener for logging defaults
org.springframework.boot.SpringApplicationRunListener=\
  tech.wanion.encryptable.config.EncryptableLoggingDefaultsRunListener

org.springframework.context.ApplicationContextInitializer=tech.wanion.encryptable.config.EncryptableMigrationSchedulerDisabler